NEXT_PUBLIC_ROOT_DOMAIN=localhost:3000
NEXT_PUBLIC_API_ENDPOINT=https://api.kurioh.com

# Neon Postgres
DATABASE_URL=

# Neon Auth (Managed Better Auth)
NEON_AUTH_BASE_URL=
NEON_AUTH_COOKIE_SECRET=

# Neon Object Storage (S3-compatible, public_read bucket) — these AWS_* names
# are auto-detected by the S3 SDK, injected by Neon for your storage bucket.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_ENDPOINT_URL_S3=
AWS_REGION=
NEON_STORAGE_BUCKET=
# Public base URL for reading objects — always AWS_ENDPOINT_URL_S3 + "/" +
# NEON_STORAGE_BUCKET, e.g. https://<branch-id>.storage.c-<N>.<region>.aws.neon.tech/<bucket>
# Used client-side to build <img> src values directly (public_read bucket).
NEXT_PUBLIC_STORAGE_URL=
